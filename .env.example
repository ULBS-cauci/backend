# System Configuration
# Copy this file to .env and fill in the correct values

# Embedding Model Configuration
EMBEDDING_CLIENT_TYPE=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=my-project-embed 

# Qdrant service
VECTOR_DB_TYPE=qdrant
VECTOR_DB_ENDPOINT=          # Full URL: http://localhost:6333
VECTOR_DB_SERVICE_API_KEY=   # Qdrant API key (keep secret!)

# Object storage
OBJECT_STORAGE_TYPE= minio
OBJECT_STORAGE_ENDPOINT=        # Full URL: http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=      # MinIO root user / IAM access key
OBJECT_STORAGE_SECRET_KEY=      # MinIO root password / IAM secret (keep secret!)
OBJECT_STORAGE_USE_SSL=         # true for production TLS (or accesing manutech.ro service), false for local HTTP (default: false)

LLM_CLIENT_TYPE=openai          # Options: "openai", "ollama"
OPENAI_API_KEY=

# Relational Database (PostgreSQL)
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=postgres_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432