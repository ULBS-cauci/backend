# System Configuration
# Copy this file to .env and fill in the correct values

ENVIRONMENT=dev                 # Required: "dev", "test", or "prod". For now, only "dev" is supported 

# Embedding Model Configuration
EMBEDDING_CLIENT_TYPE=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=my-project-embed


# Vector Database Configuration
VECTOR_DB_CLIENT_TYPE=qdrant    # Options: "qdrant"
QDRANT_ENDPOINT=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key  # Optional; only set/uncomment when Qdrant auth is enabled


# Object storage configuration
OBJECT_STORAGE_CLIENT_TYPE=minio # Options: "minio"
MINIO_ENDPOINT=http://localhost:9000
MINIO_USER=user                 # MinIO root user
MINIO_PASSWORD=password         # MinIO root password (keep secret!)
MINIO_USE_SSL=false             # true for production TLS (or accessing manutech.ro service), false for local HTTP


# LLM configuration
LLM_CLIENT_TYPE=openai          # Options: "openai", "ollama"
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2          # Default: 0.2


# Sparse encoder configuration
SPARSE_ENCODER_CLIENT_TYPE=bge-m3   # Options: "bge-m3", "bm25"
BGEM3_MODEL=BAAI/bge-m3             # Downloaded from HuggingFace Hub on first startup (~570MB); cached in ~/.cache/huggingface
BM25_MODEL=Qdrant/bm25              # Only used when SPARSE_ENCODER_CLIENT_TYPE=bm25


# Reranker configuration
RERANKER_CLIENT_TYPE=cross-encoder  # Options: "cross-encoder"
# Use "cross-encoder/ms-marco-MiniLM-L-6-v2" for a smaller, faster model with slightly lower accuracy.
CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3
# Model is downloaded from HuggingFace Hub on first startup (~570MB).
# Cached in ~/.cache/huggingface. No API key required.
CROSS_ENCODER_SCORE_THRESHOLD=0.0  # Minimum reranker score to include a chunk; tune after observing logged scores


# Relational Database configuration
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSL=false              # "false" for local dev, "true" for production with TLS
